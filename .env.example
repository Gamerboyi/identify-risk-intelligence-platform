# Environment Variables
# Copy this file to .env and set your values

# Database (local)
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Database (production - Supabase)
# DATABASE_URL=jdbc:postgresql://your-supabase-host:5432/postgres?sslmode=require

# JWT — generate a unique secret: openssl rand -hex 32
JWT_SECRET=your_64_char_hex_secret_here

# ML Service
ML_SERVICE_URL=http://localhost:5000

# CORS (comma-separated frontend origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
