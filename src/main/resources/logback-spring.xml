<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Structured JSON logging for production environments -->
    <springProfile name="prod,docker">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSS}","level":"%level","logger":"%logger{36}","traceId":"%X{traceId}","requestId":"%X{requestId}","userId":"%X{userId}","message":"%msg"}%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE" />
        </root>
    </springProfile>

    <!-- Human-readable logging for local development -->
    <springProfile name="!prod,!docker">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%X{requestId:-no-req}] %cyan(%logger{24}) - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>

        <!-- Show SQL in dev -->
        <logger name="org.hibernate.SQL" level="DEBUG" />
    </springProfile>

</configuration>
